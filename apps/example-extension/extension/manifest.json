{
  "name": "X Profile Location",
  "version": "1.1.3",
  "manifest_version": 3,
  "description": "X Profile Location",
  "icons": {
    "16": "assets/icons/icon-16x16.png",
    "32": "assets/icons/icon-32x32.png",
    "48": "assets/icons/icon-48x48.png",
    "128": "assets/icons/icon-128x128.png"
  },
  "action": {
    "default_icon": {
      "16": "assets/icons/icon-16x16.png",
      "32": "assets/icons/icon-32x32.png",
      "48": "assets/icons/icon-48x48.png",
      "128": "assets/icons/icon-128x128.png"
    },
    "default_title": "x-profile-location",
    "default_popup": "pages/options.html"
  },
  "author": {
    "email": "asmyshlyaev177+x-ext@gmail.com"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/page-script.ts-B_Y-SJui.js"
      ],
      "matches": [
        "*://*.x.com/*",
        "*://*.twitter.com/*",
        "*://x.com/*",
        "*://twitter.com/*"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "js": [
        "assets/content.tsx-loader-DEVYzAsR.js"
      ],
      "matches": [
        "*://*.x.com/*",
        "*://*.twitter.com/*",
        "*://x.com/*",
        "*://twitter.com/*"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "*://*.twitter.com/*",
        "*://*.x.com/*",
        "*://twitter.com/*",
        "*://x.com/*"
      ],
      "resources": [
        "assets/*",
        "pages/*",
        "assets/page-script.ts-B_Y-SJui.js",
        "assets/countries-CPQFDGlg.js",
        "assets/content.tsx-DWHZEvHZ.js"
      ],
      "use_dynamic_url": false
    }
  ],
  "host_permissions": [
    "*://*.x.com/*",
    "*://*.twitter.com/*"
  ],
  "permissions": [
    "storage",
    "contextMenus"
  ]
}
