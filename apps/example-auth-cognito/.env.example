# Copy to .env.local and fill in. The NEXT_PUBLIC_* vars are baked into the client
# bundle at build time and are NOT secret (a pool/client id is shipped to browsers
# normally). The COGNITO_TEST_* credentials ARE secret — they're used by the e2e
# setup to log in, and in CI they come from Actions secrets.
#
# Note: a value with a `#` must be quoted (dotenv treats unquoted `#` as a comment),
# e.g. COGNITO_TEST_PASSWORD="p@ss#word". Easiest is a password without # / * / $.

# Public Cognito config (region + the PUBLIC app client id — no client secret).
NEXT_PUBLIC_COGNITO_REGION=us-east-1
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Test user credentials (secret).
COGNITO_TEST_EMAIL=test@example.com
COGNITO_TEST_PASSWORD=Passw0rd-Change.me

# Where the app's data calls go. Inlined at BUILD time. Leave UNSET for dev/test:
# it defaults to the proxy (http://localhost:8100) so requests are recorded/replayed.
# For PRODUCTION, build with it set to the real backend (the app then talks to it
# directly, no proxy):
# NEXT_PUBLIC_API_URL=https://api.your-app.com
