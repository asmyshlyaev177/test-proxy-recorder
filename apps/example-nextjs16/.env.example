# Proxy / API configuration
#
# NOTE: Set these to the proxy address in dev/test so all requests (browser + SSR) are
# recorded/replayed. In production, point them directly at the real backend.
#
# NEXT_PUBLIC_API_URL is baked in at build time (exposed to the browser).
# BACKEND_URL is server-side only (used by SSR fetches in page.tsx).

# Dev / test — route everything through the proxy
NEXT_PUBLIC_API_URL=http://localhost:8100
BACKEND_URL=http://localhost:8100

# Production — uncomment and set the real backend URL
# NEXT_PUBLIC_API_URL=https://api.example.com
# BACKEND_URL=https://api.example.com

# Mock backend port (used by mock-backend/server.mjs)
MOCK_BACKEND_PORT=3002
