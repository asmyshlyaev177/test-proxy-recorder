---
// Code snippets render through markdown partials (src/snippets/*.md) rather
// than astro:components' <Code>. Starlight disables Astro's built-in Shiki in
// favour of Expressive Code; EC highlights markdown at build time in Node, so
// these blocks prerender to static HTML and work under the Cloudflare workerd
// prerender (where a render-time highlighter does not).
import { Content as InstallSnippet } from '../snippets/install.md';
import { Content as ConfigSnippet } from '../snippets/config.md';
import { Content as FixtureSnippet } from '../snippets/fixture.md';
import { Content as RecordSnippet } from '../snippets/record.md';
import { Content as AuthSetupSnippet } from '../snippets/auth-setup.md';
import Layout from '../layouts/Layout.astro';
import RecorderScene from '../components/RecorderScene.astro';

const repo = 'https://github.com/asmyshlyaev177/test-proxy-recorder';

const installCmd = 'npm i -D test-proxy-recorder';

// Comparison table. y = yes, n = no, p = partial (see footnote).
const compareCols = [
  'Record real traffic',
  'Server-side (SSR)',
  'Browser-side',
  'WebSocket',
  'Playwright-native',
  'Maintained',
];
const compareRows: {
  tool: string;
  self?: boolean;
  note?: string;
  cells: ('y' | 'n' | 'p')[];
}[] = [
  { tool: 'test-proxy-recorder', self: true, cells: ['y', 'y', 'y', 'y', 'y', 'y'] },
  { tool: 'Playwright routeFromHAR', cells: ['y', 'n', 'y', 'n', 'y', 'y'] },
  { tool: 'MSW', cells: ['n', 'y', 'y', 'y', 'n', 'y'] },
  { tool: 'Polly.js', cells: ['y', 'p', 'y', 'n', 'n', 'n'] },
  { tool: 'playwright-network-cache', cells: ['y', 'n', 'y', 'n', 'y', 'y'] },
  { tool: 'Mocky Balboa', cells: ['n', 'y', 'y', 'n', 'y', 'y'] },
];
const markGlyph = { y: '✓', n: '✕', p: '~' } as const;
const markText = { y: 'Yes', n: 'No', p: 'Partial' } as const;
---

<Layout>
  <!-- ============================================================ hero -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="hero-eyebrow">VCR for Playwright</p>
        <h1>Record once.<br />Replay forever.</h1>
        <p class="hero-sub">
          test-proxy-recorder captures real API responses while your Playwright suite runs
          locally, then replays them byte-for-byte on CI. No backend, no network, no
          hand-written mocks to maintain.
        </p>
        <div class="hero-actions">
          <span class="cmd">
            <code>{installCmd}</code>
            <button class="copy-btn" type="button" data-copy={installCmd}>
              <span class="copy-label">Copy</span>
            </button>
          </span>
          <a class="btn btn-ghost" href={repo}>GitHub</a>
        </div>
        <p class="hero-fine">
          MIT · TypeScript · works with Next.js SSR, SPAs &amp; Chrome extensions ·
          WebSocket support
        </p>
      </div>
      <RecorderScene />
    </div>
  </section>

  <!-- ============================================================ demo -->
  <section class="demo" id="demo">
    <div class="container demo-inner">
      <h2>See it record, then replay</h2>
      <p class="section-sub">
        One Playwright run records real responses to disk; flip to replay and the same
        suite passes with the backend off — no network.
      </p>
      <figure class="demo-frame">
        <video
          class="demo-video"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          controls
          poster="/demo-poster.jpg"
          aria-label="Screen recording: recording real API responses with test-proxy-recorder, then replaying them with the backend turned off."
        >
          <source src="/demo.webm" type="video/webm" />
          <source src="/demo.mp4" type="video/mp4" />
        </video>
      </figure>
    </div>
  </section>

  <!-- ============================================================= why -->
  <section class="why">
    <div class="container why-grid">
      <div class="why-copy">
        <h2>CI shouldn't depend on a live backend</h2>
        <p>
          Every flaky e2e run has the same root cause: the network. Hand-written mocks rot
          the moment the API changes, and spinning up a real backend on CI is slow,
          stateful, and expensive. Recording real traffic once — and replaying it
          deterministically — removes the whole failure class.
        </p>
      </div>
      <dl class="why-list">
        <div class="why-item">
          <dt>No backend on CI</dt>
          <dd>Record once against the real API, replay on every run after that.</dd>
        </div>
        <div class="why-item">
          <dt>No manual mocks</dt>
          <dd>Capture real interactions instead of hand-writing fixtures that drift.</dd>
        </div>
        <div class="why-item">
          <dt>SSR and browser-side</dt>
          <dd>Records server-side fetches (Next.js&nbsp;SSR) and browser requests alike.</dd>
        </div>
        <div class="why-item">
          <dt>Deterministic replays</dt>
          <dd>Same responses every time — including WebSocket connections.</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- ====================================================== mechanisms -->
  <section class="mechanisms">
    <div class="container">
      <h2>Two recorders, one proxy</h2>
      <p class="section-sub">
        Requests originate in two places, so there are two recording mechanisms. Use either
        one — or both together.
      </p>
      <div class="mech-grid">
        <article class="mech">
          <header class="mech-head">
            <h3>Proxy</h3>
            <code class="mech-ext">.mock.json</code>
          </header>
          <p class="mech-flow">Next.js SSR → proxy → real API</p>
          <p>
            Sits between your server and the API. Records server-side requests — SSR
            fetches, route handlers, anything your backend-for-frontend calls.
          </p>
          <p class="mech-when">For full-stack apps where the server calls the API.</p>
          <a class="mech-example" href={`${repo}/tree/master/apps/example-nextjs16`}>
            View Next.js example →
          </a>
        </article>
        <article class="mech">
          <header class="mech-head">
            <h3>HAR</h3>
            <code class="mech-ext">.har</code>
          </header>
          <p class="mech-flow">browser → HAR intercept → real API</p>
          <p>
            Intercepts in the browser itself. Records client-side <code>fetch</code> calls,
            Chrome extension API traffic, analytics, third-party APIs.
          </p>
          <p class="mech-when">For SPAs, extensions, and browser-only apps.</p>
          <a class="mech-example" href={`${repo}/tree/master/apps/example-extension`}>
            View Chrome extension example →
          </a>
        </article>
      </div>
      <p class="mech-aside">
        Technically, that makes it a <strong>man-in-the-middle</strong>. Don't worry — this
        one works for you: it intercepts your API traffic, takes meticulous notes, and the
        only thing it ever steals is the flakiness.
      </p>
    </div>
  </section>

  <!-- ======================================================= comparison -->
  <section class="compare" id="comparison">
    <div class="container">
      <h2>Where it fits</h2>
      <p class="section-sub">
        The mocking tools are good at different jobs. The combination below — recording
        real traffic across SSR, browser, and WebSockets, with no hand-written mocks — is
        the gap the others leave open.
      </p>

      <div class="compare-scroll">
        <table class="compare-table">
          <caption class="vh">
            Feature comparison of test-proxy-recorder against Playwright routeFromHAR, MSW,
            Polly.js, playwright-network-cache, and Mocky Balboa.
          </caption>
          <thead>
            <tr>
              <th scope="col"><span class="vh">Feature</span></th>
              {
                compareRows.map((row) => (
                  <th scope="col" class={row.self ? 'is-self' : undefined}>
                    {row.tool}
                    {row.note && <span class="row-note">{row.note}</span>}
                  </th>
                ))
              }
            </tr>
          </thead>
          <tbody>
            {
              compareCols.map((col, i) => (
                <tr>
                  <th scope="row">{col}</th>
                  {compareRows.map((row) => {
                    const c = row.cells[i];
                    return (
                      <td class={row.self ? 'is-self' : undefined}>
                        <span class={`mark mark-${c}`} aria-hidden="true">
                          {markGlyph[c]}
                        </span>
                        <span class="vh">{markText[c]}</span>
                      </td>
                    );
                  })}
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>

      <p class="compare-foot">
        <span class="mark mark-p" aria-hidden="true">~</span> Polly.js intercepts Node HTTP,
        so SSR mocking is possible inside the app process, but not as part of a Playwright
        run. MSW and Mocky Balboa replay real responses too — but you hand-write the mocks
        rather than recording them.
      </p>

      <div class="compare-when">
        <h3>When to reach for something else</h3>
        <ul>
          <li>
            <strong>All your traffic is browser-side.</strong> Playwright's built-in
            <code>routeFromHAR</code> is zero-dependency — start there, add this when SSR
            shows up.
          </li>
          <li>
            <strong>You want to hand-craft responses or force error and edge cases.</strong>
            MSW's authored handlers and large ecosystem fit that better, and work far
            beyond Playwright.
          </li>
          <li>
            <strong>Lightweight browser-only caching, no SSR.</strong>
            <code>playwright-network-cache</code> does just that with less to set up.
          </li>
        </ul>
        <p class="compare-credit">
          Polly.js walked so this could run — it's the inspiration, now effectively
          unmaintained.
        </p>
      </div>
    </div>
  </section>

  <!-- ======================================================= real auth -->
  <section class="auth" id="auth">
    <div class="container">
      <h2>Works with your real auth provider</h2>
      <p class="section-sub">
        Log in through Cognito, Auth0, Clerk, or WorkOS — for real, on every run.
        Only your app's API is recorded, so CI replays it with the backend off.
        Your auth stays live; your data goes offline.
      </p>
      <div class="auth-code">
        <AuthSetupSnippet />
      </div>
      <p class="auth-links">
        <a href={`${repo}/tree/master/apps/example-auth-cognito`}>AWS Cognito example →</a>
        <a href={`${repo}/tree/master/apps/example-auth-mock`}>Mock auth (no cloud account) →</a>
      </p>
    </div>
  </section>

  <!-- ====================================================== quick start -->
  <section class="quick-start" id="quick-start">
    <div class="container qs-inner">
      <h2>Deterministic in four steps</h2>
      <p class="section-sub">
        The browser-only setup, exactly as it ships. Full-stack (SSR) setup is in the
        <a href={`${repo}#full-stack-ssr--browser-quick-start`}>README</a>.
      </p>

      <ol class="steps">
        <li class="step">
          <h3>Install</h3>
          <InstallSnippet />
        </li>
        <li class="step">
          <h3>Add the proxy to <code>playwright.config.ts</code></h3>
          <p class="step-note">
            The proxy process provides session management via its <code>/__control</code>
            endpoint; for browser-only recording the target URL is never hit.
          </p>
          <ConfigSnippet />
        </li>
        <li class="step">
          <h3>Wire it into your tests</h3>
          <p class="step-note">
            One <code>beforeEach</code> covers the whole file: match the external API
            domain, pick <code>record</code> or <code>replay</code>.
          </p>
          <FixtureSnippet />
        </li>
        <li class="step">
          <h3>Record, commit, replay</h3>
          <p class="step-note">
            Recordings live in git — that's what makes CI deterministic. Don't gitignore
            them.
          </p>
          <RecordSnippet />
        </li>
      </ol>
    </div>
  </section>

  <!-- ============================================================== cta -->
  <section class="cta">
    <div class="container cta-inner">
      <h2>Stop hand-writing mocks</h2>
      <p class="cta-sub">
        Your API already gives the right answers. Record them.
      </p>
      <div class="cta-actions">
        <span class="cmd cmd-on-dark">
          <code>{installCmd}</code>
          <button class="copy-btn" type="button" data-copy={installCmd}>
            <span class="copy-label">Copy</span>
          </button>
        </span>
        <a class="btn btn-on-dark" href={repo}>Star on GitHub</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  section {
    padding-block: clamp(3.5rem, 9vw, 6.5rem);
  }

  .section-sub {
    color: var(--muted);
    margin-top: 0.7rem;
    max-width: 56ch;
  }

  .section-sub a {
    color: var(--link);
  }

  /* visually hidden — accessible text equivalents for the table marks */
  .vh {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* --------------------------------------------------------- comparison */

  .compare-scroll {
    margin-top: 2rem;
    overflow-x: auto;
  }

  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    min-width: 720px;
  }

  .compare-table th,
  .compare-table td {
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--line);
    text-align: center;
  }

  .compare-table thead th {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--ink);
    vertical-align: bottom;
    line-height: 1.25;
  }

  .compare-table thead th:first-child,
  .compare-table tbody th {
    text-align: left;
  }

  .compare-table tbody th {
    font-weight: 600;
    color: var(--ink);
    white-space: nowrap;
  }

  .row-note {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 400;
    color: var(--muted);
    margin-top: 0.15rem;
  }

  /* highlight the test-proxy-recorder column */
  .compare-table th.is-self,
  .compare-table td.is-self {
    background: var(--primary-soft);
  }

  .compare-table thead th.is-self {
    color: var(--primary-strong);
    box-shadow: inset 0 3px 0 var(--primary);
  }

  .mark {
    font-size: 1.05rem;
    line-height: 1;
  }

  .mark-y {
    color: var(--primary);
    font-weight: 700;
  }

  .mark-n {
    color: var(--muted);
    opacity: 0.55;
  }

  .mark-p {
    color: var(--rec-bright);
    font-weight: 700;
  }

  .compare-foot {
    margin-top: 1.1rem;
    color: var(--muted);
    font-size: 0.85rem;
    max-width: 70ch;
  }

  .compare-foot .mark-p {
    font-size: 0.85rem;
  }

  .compare-when {
    margin-top: 2.6rem;
  }

  .compare-when h3 {
    font-size: 1.05rem;
  }

  .compare-when ul {
    margin-top: 1rem;
    display: grid;
    gap: 0.8rem;
    padding: 0;
    list-style: none;
    max-width: 72ch;
  }

  .compare-when li {
    color: var(--muted);
    padding-left: 1.1rem;
    position: relative;
  }

  .compare-when li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--primary);
  }

  .compare-when li strong {
    color: var(--ink);
    font-weight: 600;
  }

  .compare-when code {
    font-family: var(--font-mono);
    font-size: 0.85em;
  }

  .compare-credit {
    margin-top: 1.4rem;
    color: var(--muted);
    font-size: 0.85rem;
    font-style: italic;
  }

  /* ---------------------------------------------------------- real auth */

  .auth-code {
    max-width: 640px;
    margin-top: 1.6rem;
  }

  .auth-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.4rem;
    margin-top: 1.4rem;
  }

  .auth-links a {
    color: var(--link);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  /* ------------------------------------------------------------- hero */

  .hero {
    padding-block: clamp(3.5rem, 8vw, 6rem) clamp(3rem, 7vw, 5.5rem);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--primary);
    margin-bottom: 0.9rem;
  }

  :global([data-theme='dark']) .hero-eyebrow {
    color: var(--link);
  }

  .hero-sub {
    margin-top: 1.4rem;
    font-size: var(--step-1);
    line-height: 1.55;
    color: var(--muted);
    max-width: 34ch;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.85rem;
    margin-top: 2.1rem;
  }

  .hero-fine {
    margin-top: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted);
  }

  .cmd {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    background: var(--panel);
    color: var(--panel-ink);
    border: 1px solid var(--panel-edge);
    border-radius: 9px;
    padding: 0.55rem 0.6rem 0.55rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  .cmd code::before {
    content: '$ ';
    color: var(--panel-muted);
  }

  .copy-btn {
    border: 1px solid var(--panel-edge);
    background: oklch(0.27 0.045 262);
    color: var(--panel-ink);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    border-radius: 6px;
    padding: 0.3rem 0.6rem;
    cursor: pointer;
    transition: background-color 150ms var(--ease-out);
  }

  .copy-btn:hover {
    background: oklch(0.32 0.05 262);
  }

  .copy-btn.copied {
    background: oklch(0.42 0.1 150);
    border-color: transparent;
  }

  /* ------------------------------------------------------------- demo */

  .demo {
    background: var(--surface);
    border-block: 1px solid var(--line);
  }

  .demo-inner {
    text-align: center;
    display: grid;
    justify-items: center;
  }

  .demo-frame {
    margin: 2.5rem 0 0;
    width: 100%;
    max-width: 60rem;
    border: 1px solid var(--panel-edge);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: var(--shadow-panel);
    background: var(--panel);
  }

  .demo-video {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
  }

  /* -------------------------------------------------------------- why */

  .why {
    background: var(--surface);
    border-block: 1px solid var(--line);
  }

  .why-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }

  .why-copy p {
    margin-top: 1.1rem;
    color: var(--muted);
  }

  .why-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.9rem 2.25rem;
    margin-top: 0.45rem;
  }

  .why-item dt {
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .why-item dt::before {
    content: '✓';
    color: var(--primary);
    font-weight: 700;
    margin-right: 0.5rem;
  }

  :global([data-theme='dark']) .why-item dt::before {
    color: var(--link);
  }

  .why-item dd {
    margin-top: 0.35rem;
    font-size: var(--step--1);
    color: var(--muted);
  }

  /* ------------------------------------------------------- mechanisms */

  .mech-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .mech {
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 1.7rem 1.8rem 1.8rem;
  }

  .mech p {
    margin-top: 0.85rem;
    font-size: var(--step--1);
    color: var(--muted);
  }

  .mech-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .mech-ext {
    background: var(--primary-soft);
    color: var(--primary);
    border: 0;
    font-weight: 600;
    font-size: 0.78rem;
    padding: 0.22em 0.6em;
    border-radius: 99px;
  }

  :global([data-theme='dark']) .mech-ext {
    color: var(--link);
  }

  .mech-flow {
    font-family: var(--font-mono);
    font-size: 0.78rem !important;
    color: var(--ink) !important;
    margin-top: 1rem !important;
  }

  .mech-when {
    font-weight: 600;
    color: var(--ink) !important;
  }

  .mech-example {
    display: inline-block;
    margin-top: 1.1rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--primary);
  }

  .mech-example:hover {
    text-decoration: underline;
  }

  :global([data-theme='dark']) .mech-example {
    color: var(--link);
  }

  .mech-aside {
    margin-top: 1.6rem;
    font-size: var(--step--1);
    color: var(--muted);
    max-width: 62ch;
  }

  .mech-aside strong {
    color: var(--ink);
  }

  /* ------------------------------------------------------- quick start */

  .qs-inner {
    max-width: calc(46rem + 2 * var(--gutter));
  }

  .steps {
    list-style: none;
    counter-reset: step;
    padding: 0;
    margin-top: 2.75rem;
    max-width: 46rem;
    display: grid;
    gap: 2.9rem;
  }

  .step {
    counter-increment: step;
    display: grid;
    gap: 0.85rem;
  }

  .step h3 {
    display: flex;
    align-items: baseline;
    gap: 0.85rem;
    font-size: var(--step-1);
  }

  .step h3::before {
    content: counter(step);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--primary);
    border: 1.5px solid currentColor;
    border-radius: 99px;
    width: 1.7rem;
    height: 1.7rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    translate: 0 -0.15rem;
  }

  :global([data-theme='dark']) .step h3::before {
    color: var(--link);
  }

  .step-note {
    color: var(--muted);
    font-size: var(--step--1);
    max-width: 58ch;
  }

  /* -------------------------------------------------------------- cta */

  .cta {
    background: var(--primary);
    padding-block: clamp(4rem, 10vw, 6.5rem);
  }

  :global([data-theme='dark']) .cta {
    background: oklch(0.45 0.15 262);
  }

  .cta-inner {
    text-align: center;
    display: grid;
