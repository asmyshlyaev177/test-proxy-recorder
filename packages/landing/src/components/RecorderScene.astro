<figure class="scene" aria-label="Diagram: in record mode requests flow from your app through the proxy to the real API and are saved to disk; in replay mode the proxy serves the saved responses from disk with no network.">
  <div class="scene-bar" aria-hidden="true">
    <span class="bar-dot"></span>
    <span class="bar-dot"></span>
    <span class="bar-dot"></span>
    <span class="bar-title">npx playwright test</span>
  </div>

  <div class="phase">
    <p class="phase-head rec-head">
      <span class="lamp" aria-hidden="true"></span>
      REC <span class="phase-meta">· MODE=record · local run</span>
    </p>
    <div class="track" aria-hidden="true">
      <span class="node">your app</span>
      <span class="wire">
        <span class="lane lane-1"><i class="packet packet-app"></i></span>
        <span class="lane lane-7"><i class="packet packet-play"></i></span>
      </span>
      <span class="node node-proxy">proxy</span>
      <span class="wire">
        <span class="lane lane-2"><i class="packet packet-rec"></i></span>
        <span class="lane lane-6"><i class="packet packet-rec"></i></span>
      </span>
      <span class="node">real API</span>
    </div>
    <p class="result">
      <span class="glyph-rec" aria-hidden="true">⤓</span>
      saved&ensp;<span class="result-file">e2e/recordings/todos.GET.mock.json</span>
    </p>
  </div>

  <div class="phase-divider" aria-hidden="true"></div>

  <div class="phase">
    <p class="phase-head play-head">
      <span class="play-glyph" aria-hidden="true">▶</span>
      REPLAY <span class="phase-meta">· MODE=replay · CI</span>
    </p>
    <div class="track" aria-hidden="true">
      <span class="node">your app</span>
      <span class="wire">
        <span class="lane lane-3"><i class="packet packet-play"></i></span>
        <span class="lane lane-5"><i class="packet packet-ok"></i></span>
      </span>
      <span class="node node-proxy">proxy</span>
      <span class="wire"><span class="lane lane-4"><i class="packet packet-ok"></i></span></span>
      <span class="node">disk</span>
    </div>
    <p class="result">
      <span class="glyph-play" aria-hidden="true">✓</span>
